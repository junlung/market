generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon's Vercel integration provides both URLs: the app runs through the
  // pooler, but migrations need the direct (unpooled) connection.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum MarketStatus {
  PROPOSED
  DRAFT
  REJECTED
  OPEN
  CLOSED
  RESOLVED
  CANCELED
}

// Legacy release-1 enums — dropped in the contract release along with the
// columns that use them (Postgres can't shrink an enum in place).
enum MarketOutcome {
  YES
  NO
  CANCELED
}

enum BetSide {
  YES
  NO
}

enum LedgerEntryType {
  INITIAL_GRANT
  WEEKLY_ALLOWANCE
  // per-season starting stack in FRESH_PER_SEASON leagues; idempotent per
  // (userId, seasonId) via a partial unique index (SQL-only, like isGlobal)
  SEASON_STACK
  BET_PLACED
  MARKET_PAYOUT
  MARKET_REFUND
}

// The persistent meta-currency (Phase 3, decision #5): earned from Global
// League rake/placements/achievements, spent in the store. Never interacts
// with the points economy and never resets.
enum GemLedgerEntryType {
  // one-time starting allowance, idempotent per user via a partial unique
  // (SQL-only — see partial-indexes.sql); granted at approval and by the
  // launch backfill
  STARTING_GRANT
  RAKE_CONVERSION
  ACHIEVEMENT
  SEASON_PLACEMENT
  STORE_PURCHASE
  ADMIN_ADJUST
}

enum AppLogLevel {
  INFO
  WARN
  ERROR
}

enum AppLogEventType {
  ADMIN_ACTION
  BET_FAILURE
  PROPOSAL_ACTION
  MEMBERSHIP_ACTION
}

enum NotificationType {
  PROPOSAL_SUBMITTED
  MEMBER_PENDING
  FEEDBACK_SUBMITTED
  MARKET_AWAITING_RESOLUTION
  MARKET_RESOLVED
  MARKET_CANCELED
  PROPOSAL_APPROVED
  PROPOSAL_REJECTED
  MEMBER_APPROVED
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

// Cosmetic/trophy inventory (see docs/social-features-plan.md). TROPHY is
// display-only; the other kinds map 1:1 onto EquipSlot values.
enum ItemKind {
  TROPHY
  BADGE
  TITLE
  FRAME
  BACKGROUND
}

enum ItemSource {
  SEASON_TROPHY
  ACHIEVEMENT
  PURCHASE
  ADMIN_GRANT
}

enum EquipSlot {
  BADGE
  TITLE
  FRAME
  BACKGROUND
}

// Leagues (see docs/social-features-plan.md, Phase 2). Phase 2a ships only
// the Global League; joinPolicy/ownerId/roles come alive with user-created
// leagues in 2b.
enum LeagueJoinPolicy {
  INVITE_CODE
  APPROVAL
}

enum LeagueBalancePolicy {
  PERSISTENT
  FRESH_PER_SEASON
}

enum LeagueRole {
  OWNER
  MOD
  MEMBER
}

enum SeasonStatus {
  UPCOMING
  ACTIVE
  FINALIZED
}

enum LeagueInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  // stable lowercase handle for profile URLs (/u/[username]) — display names
  // stay mutable and non-unique; migration backfilled this from `name`
  username     String     @unique
  bio          String?
  passwordHash String
  role         UserRole   @default(MEMBER)
  status       UserStatus @default(PENDING)

  // up to 3 achievement keys (src/lib/achievements.ts) highlighted on the
  // profile; validated against earned achievements in the service
  showcasedAchievements String[] @default([])

  // membership review audit
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?

  // a member vouching for a pending account (visible to admins in the queue)
  vouchedById  String?
  vouchedBy    User?   @relation("Vouches", fields: [vouchedById], references: [id], onDelete: SetNull)
  vouchNote    String?
  vouchesGiven User[]  @relation("Vouches")

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  bets              Bet[]
  poolStakes        PoolStake[]
  ledgerEntries     LedgerEntry[]
  comments          Comment[]
  appLogs           AppLog[]
  items             UserItem[]
  gemLedgerEntries  GemLedgerEntry[]
  leagueMemberships LeagueMembership[]
  ownedLeagues      League[]           @relation("LeagueOwner")

  leagueInvitesReceived LeagueInvite[] @relation("LeagueInvitesReceived")
  leagueInvitesSent     LeagueInvite[] @relation("LeagueInvitesSent")
  feedback              Feedback[]
  notifications         Notification[]

  @@index([status, createdAt])
}

// A cosmetic/trophy definition. `style` holds kind-specific rendering params
// (emoji, colors, CSS tokens) — items are drawn, never uploaded, so there is
// no image storage. storeCost null = not purchasable (trophies never are).
model Item {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  kind        ItemKind
  style       Json?
  storeCost   Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  userItems        UserItem[]
  gemLedgerEntries GemLedgerEntry[]
}

// One granted instance of an Item in a user's inventory. Duplicates of the
// same Item are allowed when provenance differs (e.g. the same championship
// trophy won in two different seasons).
model UserItem {
  id           String     @id @default(cuid())
  userId       String
  itemId       String
  source       ItemSource
  // e.g. { "league": "Global League", "seasonId": "...", "placement": 1 }
  provenance   Json?
  // idempotency key for automated grants (season finalization, achievements)
  // — same pattern as LedgerEntry [userId, allowanceWeek]. Null for manual
  // grants and purchases.
  grantKey     String?    @unique
  // at most one equipped item per slot, enforced in the equip transaction
  // (Prisma can't express a partial unique index)
  equippedSlot EquipSlot?
  grantedAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId, grantedAt])
  @@index([itemId])
}

// A competition context: markets, memberships, seasons, and ledger entries
// are all league-scoped. Exactly one row has isGlobal = true (enforced by a
// partial unique index in SQL — Prisma can't express it); the global league
// has no owner and a PERSISTENT balance policy (seasons are leaderboard
// windows, not economy resets — decision #3).
model League {
  id            String              @id @default(cuid())
  slug          String              @unique
  name          String
  description   String?
  isGlobal      Boolean             @default(false)
  ownerId       String?
  owner         User?               @relation("LeagueOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  joinPolicy    LeagueJoinPolicy    @default(INVITE_CODE)
  balancePolicy LeagueBalancePolicy @default(FRESH_PER_SEASON)

  // the single rotating join code (regenerate to revoke). Null for the
  // global league — nobody joins it by code.
  inviteCode String? @unique

  // economy settings custom-league markets inherit (2b kickoff decision #2).
  // Set at creation, locked once the first season starts. The global league
  // keeps matching appConfig; its settings columns are display-only.
  startingStack          Int @default(500)
  weeklyAllowance        Int @default(100)
  defaultRakeBps         Int @default(500)
  defaultMaxStakePerUser Int @default(500)

  createdAt DateTime @default(now())

  memberships   LeagueMembership[]
  seasons       Season[]
  markets       Market[]
  ledgerEntries LedgerEntry[]
  invites       LeagueInvite[]
}

// Everyone auto-joins the global league (backfilled in the migration, granted
// at account approval for new members). Roles gate nothing in 2a — app admins
// keep running the Global League; per-league permissions arrive in 2b.
model LeagueMembership {
  id       String     @id @default(cuid())
  leagueId String
  userId   String
  role     LeagueRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@index([userId])
}

// A personal invitation into a custom league — joining is always the
// invitee's choice (accept/decline), never a direct add. At most one PENDING
// invite per (leagueId, userId) via a partial unique index in SQL — Prisma
// can't express it (LeagueInvite_pending_key, see partial-indexes.sql).
// Declined rows are kept (re-invite creates a fresh PENDING row); revoking
// deletes the PENDING row outright.
model LeagueInvite {
  id          String             @id @default(cuid())
  leagueId    String
  userId      String // the invitee
  invitedById String?
  status      LeagueInviteStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  respondedAt DateTime?

  league    League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      User   @relation("LeagueInvitesReceived", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?  @relation("LeagueInvitesSent", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([leagueId, status])
}

// A leaderboard window. Global League seasons are UTC calendar months,
// opened lazily on read (like the weekly allowance) and finalized by the
// daily cron, which freezes `standings` and grants the trophies.
model Season {
  id          String       @id @default(cuid())
  leagueId    String
  index       Int
  name        String
  startsAt    DateTime
  endsAt      DateTime
  status      SeasonStatus @default(ACTIVE)
  finalizedAt DateTime?
  // frozen at finalization: ranked participants
  // [{ userId, name, username, score, marketsSettled, marketsWon, rank }]
  standings   Json?

  league           League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  markets          Market[]
  ledgerEntries    LedgerEntry[]
  gemLedgerEntries GemLedgerEntry[]

  @@unique([leagueId, index])
  @@unique([leagueId, startsAt])
  @@index([leagueId, status])
}

model Market {
  id               String       @id @default(cuid())
  title            String
  description      String
  category         String
  closeTime        DateTime
  resolveTime      DateTime
  resolutionSource String
  status           MarketStatus @default(DRAFT)

  // every market lives in exactly one league (backfilled to the Global
  // League); a market never moves leagues (decisions log, Phase 2)
  leagueId String
  league   League  @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  // pinned season for FRESH_PER_SEASON leagues — its stakes/payouts belong
  // to that season's stack. Null in PERSISTENT leagues (the Global League).
  seasonId String?
  season   Season? @relation(fields: [seasonId], references: [id], onDelete: Restrict)

  // Invariant: RESOLVED ⇒ winningOutcomeId != null. CANCELED derives from
  // status alone. Restrict: a winning outcome row can never be deleted from
  // under its market.
  winningOutcomeId String?
  winningOutcome   Outcome?  @relation("MarketWinningOutcome", fields: [winningOutcomeId], references: [id], onDelete: Restrict)
  outcomes         Outcome[] @relation("MarketOutcomes")

  // legacy release-1 columns, dual-written for binary markets — dropped in
  // the contract release
  finalOutcome MarketOutcome?
  yesPool      Int            @default(0)
  noPool       Int            @default(0)

  // economy snapshots frozen at creation; admin-editable until first bet
  rakeBps         Int @default(500)
  maxStakePerUser Int

  // provenance + proposal review
  createdById  String
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  openedById   String?
  openedAt     DateTime?
  closedById   String?
  closedAt     DateTime?
  resolvedById String?
  resolvedAt   DateTime?
  canceledById String?
  canceledAt   DateTime?
  firstBetAt   DateTime?
  lastBetAt    DateTime?

  bets             Bet[]
  poolStakes       PoolStake[]
  ledgerEntries    LedgerEntry[]
  gemLedgerEntries GemLedgerEntry[]
  comments         Comment[]
  resolution       MarketResolution?
  appLogs          AppLog[]

  @@index([status, closeTime])
  @@index([category, status])
  @@index([createdById, status])
  @@index([leagueId, status])
  @@index([seasonId, status])
}

// One named outcome of a market (2–6 per market, fixed at creation).
// `pool` is the live parimutuel pool; `poolFinal` is frozen at settlement so
// the conservation audit stays in typed ints: Σ poolFinal = winningPool + losingPool.
model Outcome {
  id        String  @id @default(cuid())
  marketId  String
  label     String
  // a curated token (see outcome-colors.ts) or a custom "#rrggbb" hex
  color     String
  // optional decoration shown next to the label (e.g. "⚽")
  emoji     String?
  pool      Int     @default(0)
  poolFinal Int?
  sortOrder Int

  market     Market      @relation("MarketOutcomes", fields: [marketId], references: [id], onDelete: Cascade)
  wonMarkets Market[]    @relation("MarketWinningOutcome")
  bets       Bet[]
  poolStakes PoolStake[]

  @@unique([marketId, sortOrder])
  @@index([marketId])
}

model Bet {
  id       String @id @default(cuid())
  userId   String
  marketId String
  amount   Int

  // snapshots frozen at bet time — authoritative for O(1) activity feeds,
  // and they survive user cascade-deletes (full replay only happens inside
  // the market-detail chart where all bets are loaded anyway)
  outcomeId        String
  outcomePoolAfter Int
  totalPoolAfter   Int

  // legacy release-1 columns, dual-written for binary markets — dropped in
  // the contract release
  side         BetSide?
  yesPoolAfter Int?
  noPoolAfter  Int?

  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  market        Market        @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome       Outcome       @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]

  @@index([marketId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// A user's aggregate stake on one outcome. Rows exist only where amount > 0.
model PoolStake {
  id        String @id @default(cuid())
  userId    String
  marketId  String
  outcomeId String
  amount    Int    @default(0)

  // legacy release-1 columns, dual-written for binary markets — dropped in
  // the contract release
  yesStake Int @default(0)
  noStake  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome   Outcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId, outcomeId])
  @@index([marketId])
}

model LedgerEntry {
  id            String          @id @default(cuid())
  userId        String
  // the points economy this entry belongs to (backfilled to the Global
  // League); seasonId additionally scopes FRESH_PER_SEASON stacks — a
  // season's balance = SUM over (leagueId, seasonId)
  leagueId      String
  seasonId      String?
  marketId      String?
  betId         String?
  type          LedgerEntryType
  amount        Int
  allowanceWeek String?
  description   String
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  league        League          @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  season        Season?         @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  market        Market?         @relation(fields: [marketId], references: [id], onDelete: SetNull)
  bet           Bet?            @relation(fields: [betId], references: [id], onDelete: SetNull)

  // one allowance per user per league per week (SEASON_STACK idempotency is
  // a partial unique on [userId, seasonId] — SQL-only, like League.isGlobal)
  @@unique([userId, leagueId, allowanceWeek])
  @@index([userId, createdAt])
  @@index([marketId, createdAt])
  @@index([leagueId, userId])
}

model MarketResolution {
  id               String  @id @default(cuid())
  marketId         String  @unique
  // null = canceled (refund all); the winning Outcome id otherwise
  winningOutcomeId String?
  resolutionSource String
  notes            String?
  // settlement audit — burned points are recorded here, not in the user ledger.
  // Invariant: winningPool + losingPool === totalPaidOut + rakeAmount + dustAmount,
  // and Σ Outcome.poolFinal === winningPool + losingPool
  winningPool      Int
  losingPool       Int
  rakeAmount       Int
  dustAmount       Int
  totalPaidOut     Int
  // gems minted from this market's rake (Phase 3): Σ RAKE_CONVERSION entries.
  // Invariant: gemsMinted <= rakeAmount (floor rounding drops "gem dust").
  gemsMinted       Int     @default(0)

  // legacy release-1 columns, dual-written for binary markets — dropped in
  // the contract release
  outcome      MarketOutcome?
  yesPoolFinal Int?
  noPoolFinal  Int?

  createdById String
  createdAt   DateTime @default(now())
  market      Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
}

// Append-only gems ledger; balance = SUM(amount) per user (no league scoping —
// gems are one global wallet). Exactly one provenance anchor is set per type:
// marketId (RAKE_CONVERSION), seasonId (SEASON_PLACEMENT), achievementKey
// (ACHIEVEMENT), itemId (STORE_PURCHASE, amount negative). Idempotency for
// rake/placement grants lives in SQL partial uniques (see partial-indexes.sql);
// achievementKey uses a plain composite unique since NULLs are distinct.
model GemLedgerEntry {
  id             String             @id @default(cuid())
  userId         String
  type           GemLedgerEntryType
  amount         Int
  marketId       String?
  seasonId       String?
  achievementKey String?
  itemId         String?
  description    String
  createdAt      DateTime           @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market? @relation(fields: [marketId], references: [id], onDelete: SetNull)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  item   Item?   @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@unique([userId, achievementKey])
  @@index([userId, createdAt])
  @@index([marketId])
}

model Comment {
  id        String   @id @default(cuid())
  marketId  String
  userId    String
  body      String
  createdAt DateTime @default(now())
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
}

model Feedback {
  id         String    @id @default(cuid())
  userId     String
  message    String
  // page the member was on when they opened the dialog — relative path,
  // display-only in the admin list (user-forgeable, never rendered as a link)
  path       String?
  createdAt  DateTime  @default(now())
  // triage flag, toggleable by admins; null = unresolved
  resolvedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resolvedAt, createdAt])
}

model AppLog {
  id        String          @id @default(cuid())
  level     AppLogLevel
  eventType AppLogEventType
  message   String
  userId    String?
  marketId  String?
  metadata  Json?
  createdAt DateTime        @default(now())
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  market    Market?         @relation(fields: [marketId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           // recipient
  type      NotificationType
  title     String
  body      String?
  // canonical in-app destination, constructed server-side at emission
  // (marketPath() or a fixed admin route) — never user input, safe as a Link
  href      String
  // idempotency for re-emittable paths — same pattern as UserItem.grantKey:
  // plain nullable unique, try-create + swallow P2002. Null for one-shot
  // emissions that can't mechanically double-fire (member pending/approved).
  dedupeKey String?          @unique
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}
