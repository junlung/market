generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Neon's Vercel integration provides both URLs: the app runs through the
  // pooler, but migrations need the direct (unpooled) connection.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum MarketStatus {
  PROPOSED
  DRAFT
  REJECTED
  OPEN
  CLOSED
  RESOLVED
  CANCELED
}

// Legacy release-1 enums — dropped in the contract release along with the
// columns that use them (Postgres can't shrink an enum in place).
enum MarketOutcome {
  YES
  NO
  CANCELED
}

enum BetSide {
  YES
  NO
}

enum LedgerEntryType {
  INITIAL_GRANT
  WEEKLY_ALLOWANCE
  BET_PLACED
  MARKET_PAYOUT
  MARKET_REFUND
}

enum AppLogLevel {
  INFO
  WARN
  ERROR
}

enum AppLogEventType {
  ADMIN_ACTION
  BET_FAILURE
  PROPOSAL_ACTION
  MEMBERSHIP_ACTION
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole   @default(MEMBER)
  status       UserStatus @default(PENDING)

  // membership review audit
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?

  // a member vouching for a pending account (visible to admins in the queue)
  vouchedById  String?
  vouchedBy    User?      @relation("Vouches", fields: [vouchedById], references: [id], onDelete: SetNull)
  vouchNote    String?
  vouchesGiven User[]     @relation("Vouches")

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bets          Bet[]
  poolStakes    PoolStake[]
  ledgerEntries LedgerEntry[]
  comments      Comment[]
  appLogs       AppLog[]

  @@index([status, createdAt])
}

model Market {
  id               String            @id @default(cuid())
  title            String
  description      String
  category         String
  closeTime        DateTime
  resolveTime      DateTime
  resolutionSource String
  status           MarketStatus      @default(DRAFT)

  // Invariant: RESOLVED ⇒ winningOutcomeId != null. CANCELED derives from
  // status alone. Restrict: a winning outcome row can never be deleted from
  // under its market.
  winningOutcomeId String?
  winningOutcome   Outcome? @relation("MarketWinningOutcome", fields: [winningOutcomeId], references: [id], onDelete: Restrict)
  outcomes         Outcome[] @relation("MarketOutcomes")

  // legacy release-1 columns, dual-written for binary markets — dropped in
  // the contract release
  finalOutcome MarketOutcome?
  yesPool      Int            @default(0)
  noPool       Int            @default(0)

  // economy snapshots frozen at creation; admin-editable until first bet
  rakeBps         Int @default(500)
  maxStakePerUser Int

  // provenance + proposal review
  createdById  String
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  openedById   String?
  openedAt     DateTime?
  closedById   String?
  closedAt     DateTime?
  resolvedById String?
  resolvedAt   DateTime?
  canceledById String?
  canceledAt   DateTime?
  firstBetAt   DateTime?
  lastBetAt    DateTime?

  bets          Bet[]
  poolStakes    PoolStake[]
  ledgerEntries LedgerEntry[]
  comments      Comment[]
  resolution    MarketResolution?
  appLogs       AppLog[]

  @@index([status, closeTime])
  @@index([category, status])
  @@index([createdById, status])
}

// One named outcome of a market (2–6 per market, fixed at creation).
// `pool` is the live parimutuel pool; `poolFinal` is frozen at settlement so
// the conservation audit stays in typed ints: Σ poolFinal = winningPool + losingPool.
model Outcome {
  id        String  @id @default(cuid())
  marketId  String
  label     String
  color     String
  pool      Int     @default(0)
  poolFinal Int?
  sortOrder Int

  market     Market      @relation("MarketOutcomes", fields: [marketId], references: [id], onDelete: Cascade)
  wonMarkets Market[]    @relation("MarketWinningOutcome")
  bets       Bet[]
  poolStakes PoolStake[]

  @@unique([marketId, sortOrder])
  @@index([marketId])
}

model Bet {
  id       String @id @default(cuid())
  userId   String
  marketId String
  amount   Int

  // snapshots frozen at bet time — authoritative for O(1) activity feeds,
  // and they survive user cascade-deletes (full replay only happens inside
  // the market-detail chart where all bets are loaded anyway)
  outcomeId        String
  outcomePoolAfter Int
  totalPoolAfter   Int

  // legacy release-1 columns, dual-written for binary markets — dropped in
  // the contract release
  side         BetSide?
  yesPoolAfter Int?
  noPoolAfter  Int?

  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  market        Market        @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome       Outcome       @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]

  @@index([marketId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// A user's aggregate stake on one outcome. Rows exist only where amount > 0.
model PoolStake {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  outcomeId String
  amount    Int      @default(0)

  // legacy release-1 columns, dual-written for binary markets — dropped in
  // the contract release
  yesStake Int @default(0)
  noStake  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome   Outcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId, outcomeId])
  @@index([marketId])
}

model LedgerEntry {
  id            String          @id @default(cuid())
  userId        String
  marketId      String?
  betId         String?
  type          LedgerEntryType
  amount        Int
  allowanceWeek String?
  description   String
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  market        Market?         @relation(fields: [marketId], references: [id], onDelete: SetNull)
  bet           Bet?            @relation(fields: [betId], references: [id], onDelete: SetNull)

  @@unique([userId, allowanceWeek])
  @@index([userId, createdAt])
  @@index([marketId, createdAt])
}

model MarketResolution {
  id               String  @id @default(cuid())
  marketId         String  @unique
  // null = canceled (refund all); the winning Outcome id otherwise
  winningOutcomeId String?
  resolutionSource String
  notes            String?
  // settlement audit — burned points are recorded here, not in the user ledger.
  // Invariant: winningPool + losingPool === totalPaidOut + rakeAmount + dustAmount,
  // and Σ Outcome.poolFinal === winningPool + losingPool
  winningPool  Int
  losingPool   Int
  rakeAmount   Int
  dustAmount   Int
  totalPaidOut Int

  // legacy release-1 columns, dual-written for binary markets — dropped in
  // the contract release
  outcome      MarketOutcome?
  yesPoolFinal Int?
  noPoolFinal  Int?

  createdById String
  createdAt   DateTime @default(now())
  market      Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  marketId  String
  userId    String
  body      String
  createdAt DateTime @default(now())
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
}

model AppLog {
  id        String          @id @default(cuid())
  level     AppLogLevel
  eventType AppLogEventType
  message   String
  userId    String?
  marketId  String?
  metadata  Json?
  createdAt DateTime        @default(now())
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  market    Market?         @relation(fields: [marketId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
}
