DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prollymarket_v2"
# Same as DATABASE_URL locally; on Vercel the Neon integration provides the
# unpooled variant automatically (Prisma migrations need a direct connection).
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/prollymarket_v2"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
SEED_DEFAULT_PASSWORD="password123"

# Shared secret for cron routes (api/cron/*). Vercel sends it automatically
# as `Authorization: Bearer <CRON_SECRET>` on scheduled invocations; the
# routes reject everything when it's unset.
CRON_SECRET="replace-with-a-long-random-secret"

# Economy (integer points)
STARTING_BALANCE="500"
WEEKLY_ALLOWANCE="100"
RAKE_BPS="500"
DEFAULT_MAX_STAKE_PER_USER="500"
MAX_BET_AMOUNT="250"

# Rate limiting
BET_RATE_LIMIT_WINDOW_MS="10000"
BET_RATE_LIMIT_MAX_REQUESTS="5"

# Integration tests only (separate throwaway database)
# TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prollymarket_v2_test"
